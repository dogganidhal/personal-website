---
import Layout from '~/layouts/Layout.astro';
import Hero from '~/components/sections/Hero.astro';
import About from '~/components/sections/About.astro';
import ExperienceList from '~/components/sections/ExperienceList.astro';
import ProjectList from '~/components/sections/ProjectList.astro';
import Contact from '~/components/sections/Contact.astro';
import { t } from '~/i18n';

const lang = 'en' as const;
---
<Layout
  title="Nidhal Dogga · Software Engineer"
  description={t('hero.tagline', lang)}
  lang={lang}
>
  <Hero lang={lang} />
  <About lang={lang} />
  <ExperienceList lang={lang} />
  <ProjectList lang={lang} category="oss" headingKey="section.opensource" />
  <ProjectList lang={lang} category="project" headingKey="section.projects" />
  <Contact lang={lang} />
</Layout>
