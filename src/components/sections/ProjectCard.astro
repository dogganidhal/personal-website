---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '~/i18n';

interface Props {
  entry: CollectionEntry<'projects'>;
  lang: Lang;
}

const { entry, lang } = Astro.props;
const { title, description, url, repo, tags, status } = entry.data;
const primaryHref = url ?? repo;
const secondaryHref = url && repo ? repo : undefined;
const archivedLabel = lang === 'fr' ? 'Archivé' : 'Archived';
---
<li>
  <div class="flex items-baseline justify-between gap-4 flex-wrap">
    <h3 class="font-medium text-zinc-900 dark:text-zinc-100">
      {primaryHref
        ? <a href={primaryHref} target="_blank" rel="noopener noreferrer" class="hover:text-zinc-600 dark:hover:text-zinc-400 transition-colors">{title}</a>
        : title}
    </h3>
    {status === 'archived' && (
      <span class="font-mono text-xs text-zinc-500 uppercase tracking-wide">
        {archivedLabel}
      </span>
    )}
  </div>
  <p class="mt-2 text-sm text-zinc-700 dark:text-zinc-300 leading-relaxed">{description}</p>
  {(tags.length > 0 || secondaryHref) && (
    <div class="mt-3 flex items-center gap-3 flex-wrap">
      {tags.length > 0 && (
        <ul class="flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <li class="font-mono text-xs px-1.5 py-0.5 rounded text-zinc-500 bg-zinc-100 dark:bg-zinc-900">
              {tag}
            </li>
          ))}
        </ul>
      )}
      {secondaryHref && (
        <a href={secondaryHref} target="_blank" rel="noopener noreferrer" class="font-mono text-xs text-zinc-500 hover:text-zinc-900 dark:hover:text-zinc-100 underline underline-offset-2 transition-colors">
          GitHub →
        </a>
      )}
    </div>
  )}
</li>
